generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Product {
  id             String    @id @default(cuid())
  name           String    @db.VarChar(160)
  description    String?   @db.Text
  photoBucket    String?   @map("photo_bucket") @db.VarChar(255)
  photoObjectKey String?   @map("photo_object_key") @db.VarChar(1024)
  photoUrl       String?   @map("photo_url") @db.VarChar(2048)
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")
  deletedAt      DateTime? @map("deleted_at")
  combinations   ProductCombination[]

  @@index([deletedAt])
  @@index([updatedAt])
  @@map("products")
}

model ProductCombination {
  id        String    @id @default(cuid())
  productId String    @map("product_id")
  name      String    @db.VarChar(120)
  hexColor  String    @map("hex_color") @db.VarChar(7)
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")
  product   Product   @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId, deletedAt])
  @@index([updatedAt])
  @@map("product_combinations")
}
